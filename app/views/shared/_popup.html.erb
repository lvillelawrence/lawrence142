<div data-controller="popup">
  <div data-popup-target="overlay" class="popup-overlay" style="display: none;">
    <div class="popup-content">
      <div class="popup-header">
        <h3>Welcome!</h3>
        <button class="popup-close" aria-label="Close" data-action="click->popup#close">&times;</button>
      </div>
      <div class="popup-body">
        <p>This is an important message for visitors of this website.</p>
        <p>By clicking on the checkbox below, you agree to not share any content or the link to <i>The Lawrence</i>'s website with <b>anyone</b>.</p>
        <div class="form-check mt-3">
          <input class="form-check-input" type="checkbox" id="agreeCheckbox" data-popup-target="checkbox">
          <label class="form-check-label" for="agreeCheckbox">
            I agree
          </label>
        </div>
      </div>
      <div class="popup-footer">
        <button class="popup-checkbox-btn btn btn-primary" data-action="click->popup#dismiss">
          Continue
        </button>
      </div>
    </div>
  </div>
</div>

