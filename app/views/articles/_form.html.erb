<%= form_with model: article do |form| %>
  <div class="form-floating mb-3">
    <%= form.text_field :title, class: "form-control", placeholder: "..." %>
    <%= form.label :title, class: "form-label" %>
    <% article.errors.full_messages_for(:title).each do |message| %>
      <div class="invalid-feedback"><%= message %></div>
    <% end %>
  </div>

  <div class="mb-3 d-none">
    <%= form.collection_select(:author_ids, Author.all, :id, :fullname, {:prompt => true, :include_blank => false}, {class: "form-control", multiple: true, "data-live-search": true, id: "authors"}) %>
    <%= form.label :author, class: "form-label" %>
    <% article.errors.full_messages_for(:author).each do |message| %>
      <div class="invalid-feedback"><%= message %></div>
    <% end %>
  </div>

  <div class="form-floating mb-3">
    <input class="form-control" id="pseudoInput" type="text" placeholder="...">
    <label for="pseudoInput">Search</label>
    <div style="overflow:scroll;height:200px;">
      <table class="table table-sm">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col">Name</th>
          </tr>
        </thead>
        <tbody id="pseudoTable">
          <% Author.all.each do |author| %>
            <tr>
              <th scope="row">
                <input class="form-check-input pseudo-select" type="checkbox" value="" data-id="<%= author.id %>" <%= article.author_ids.include?(author.id) ? "checked='checked'" : "" %>>
              </th>
              <td><%= author.fullname %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :image, class: "form-label" %>
    <% if article.image.present? %>
      <div class="alert alert-danger d-flex align-items-center" role="alert">
        <div>
          This entity already has an attachment associated with it. Uploading a new one will replace the existing one.
        </div>
      </div>
    <% end %>
    <%= form.file_field :image, class: "form-control" %>
    <% article.errors.full_messages_for(:image).each do |message| %>
      <div class="invalid-feedback"><%= message %></div>
    <% end %>
  </div>

  <div class="form-floating mb-3">
    <%= form.text_field :image_credit, class: "form-control", placeholder: "..." %>
    <%= form.label :image_credit, "Photo/Graphic Credit", class: "form-label" %>
    <small class="text-muted">e.g., "Photo by Jane Doe '25" or "Graphic by John Smith '24"</small>
  </div>

  <div class="mb-3">
    <%= form.label :body, class: "form-label" %>
    <%= form.rich_text_area :body, class: "form-control" %>
    <% article.errors.full_messages_for(:body).each do |message| %>
      <div class="invalid-feedback"><%= message %></div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= form.label :published, "Publish date & time", class: "form-label" %>
    <%= form.datetime_field :published, class: "form-control", step: 60 %>
    <small class="text-muted d-block mt-1">The article appears on the homepage and in sections after this moment. Times use the site timezone (Eastern).</small>
  </div>

  <div class="mb-3">
    <%= form.label :status, class: "form-label" %>
    <%= form.select :status, Visible::VALID_STATUSES, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :section, class: "form-label" %>
    <%= form.select :section, Article::VALID_SECTIONS, {}, class: "form-select" %>
  </div>

  <%= form.submit %>
<% end %>
<%= javascript_include_tag "article_form" %>