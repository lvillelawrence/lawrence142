<h1><%= @article.title %></h1>
<p>
  <% @article.authors.each_with_index do |author, i| %>
    <a href="<%= url_for author %>" class="text-primary text-decoration-underline"><small><b><%= author.fullname %><%= author.gradyear.blank? ? "" : " '#{author.gradyear.to_s[-2..-1]}" %></b><%= author.position.present? ? " (#{author.position})" : "" %><%= (@article.authors.count > 2 and i != @article.authors.count - 1) ? ", " : "" %><%= (@article.authors.count > 1 and i == @article.authors.count - 2) ? " and " : "" %></small></a>
  <% end %>
  in <a href="/sections/<%= @article.section&.downcase %>" class="text-decoration-none text-reset"><i><%= @article.section %></i></a> | <%= @article.published_at_for_display %>
</p>
<% img_src = article_hero_image_url(@article) %>
<% if img_src %>
  <figure class="figure w-100">
    <img class="img-fluid mx-0 px-0 figure-img" src="<%= img_src %>" alt="" />
    <% if @article.image_credit.present? %>
      <figcaption class="figure-caption text-end"><small><em><%= @article.image_credit %></em></small></figcaption>
    <% end %>
  </figure>
<% elsif @article.image_credit.present? %>
  <%# Credit was saved but hero uses inline/body image only — still show attribution %>
  <p class="text-end small text-muted mb-2"><em><%= @article.image_credit %></em></p>
<% end %>
<% begin %>
<%= @article.body %>
<% rescue StandardError => e %>
  <% Rails.logger.error("[articles#show body id=#{@article.id}] #{e.class}: #{e.message}") %>
  <div class="trix-content"><p class="text-muted">Article text could not be loaded.</p></div>
<% end %>

<% if admin_signed_in? %>
  <div class="hstack gap-3">
    <%= link_to "Edit", edit_article_path(@article) %>
    <%= button_to "Destroy", article_path(@article), data: {
                      turbo_method: :delete,
                      turbo_confirm: "Are you sure?"
                    }, :method => :delete, class: "btn btn-link" %>
  </div>
<% end %>
